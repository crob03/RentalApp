{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.csproj"],
          "exclude": ["**/obj/**", "**/bin/**", "**/Views/**", "**/Platforms/**", "**/RentalApp.Test/**", "**/RentalApp.Migrations/**"]
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "allowCompilationErrors": true
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml"]
      },
      {
        "files": ["toc.yml", "*.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appName": "RentalApp",
      "_appTitle": "RentalApp Documentation",
      "_enableSearch": true
    },
    "template": ["default", "modern"]
  }
}
