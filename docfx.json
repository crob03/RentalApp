{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": ["**/*.cs"],
          "exclude": [
            "**/obj/**",
            "**/bin/**",
            "**/Platforms/Windows/**",
            "**/Platforms/iOS/**",
            "**/Platforms/MacCatalyst/**",
            "**/Platforms/Tizen/**",
            "RentalApp.Test/**",
            "RentalApp.Migrations/Migrations/**"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["toc.yml", "README.md", "DECISIONS.md"]
      }
    ],
    "resource": [],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "RentalApp",
      "_appTitle": "RentalApp Documentation",
      "_enableSearch": true
    }
  }
}
