<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  x:Class="RentalApp.Views.CreateReviewPage"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:vm="clr-namespace:RentalApp.ViewModels"
  Title="{Binding Title}"
  x:DataType="vm:CreateReviewViewModel"
>
  <ContentPage.Content>
    <VerticalStackLayout Padding="16" Spacing="16">
      <Label Text="Leave a Review" FontSize="20" FontAttributes="Bold" />
    </VerticalStackLayout>
  </ContentPage.Content>
</ContentPage>
