# Doxyfile for RentalApp
# Only non-default settings are listed here for maintainability.

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "RentalApp"
PROJECT_BRIEF          = "A .NET MAUI cross-platform rental application"
USE_MDFILE_AS_MAINPAGE = README.md

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = README.md \
                         RentalApp \
                         RentalApp.Database \
                         RentalApp.Migrations
RECURSIVE              = YES
FILE_PATTERNS          = *.cs *.md
EXCLUDE_PATTERNS       = */obj/* \
                         */bin/* \
                         */Platforms/Windows/* \
                         */Platforms/iOS/* \
                         */Platforms/MacCatalyst/* \
                         */Platforms/Tizen/*

#---------------------------------------------------------------------------
# Extraction — show all members even without doc comments
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

#---------------------------------------------------------------------------
# Output
#---------------------------------------------------------------------------
OUTPUT_DIRECTORY       = docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html

#---------------------------------------------------------------------------
# Diagrams (requires dot/graphviz — disabled to keep CI fast)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
